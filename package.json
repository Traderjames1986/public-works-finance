{
  "name": "public-works-finance",
  "version": "1.0.0",
  "description": "Public Works Department Financial Management System",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon --exec babel-node server/index.js",
    "server:build": "babel server -d dist",
    "server:start": "node dist/index.js",
    "client:dev": "cd client && npm start",
    "client:build": "cd client && npm run build",
    "build": "npm run server:build && npm run client:build",
    "db:migrate": "node server/migrations/migrate.js",
    "test": "jest",
    "lint": "eslint ."
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "uuid": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.1.0",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "moment": "^2.29.4"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/node": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0"
  }
}
